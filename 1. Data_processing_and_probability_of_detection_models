#Filtering playback_true detections only 
playback_truedet <- raw_detections %>%
  filter(verification_category == "playback_true", 
         is_true_detection == 1, 
         is_target == 1) %>%
  mutate(
    distance_m = as.character(distance_m),
    transect_id = gsub(" ", "_", trimws(transect_id))  # Fix naming inconsistencies
  )


#Defining variables for zero-filled grid
species <- c("Corvus corax", "Streptopelia decaocto", "Corvus corone", "Columba oenas", 
             "Columba palumbus", "Periparus ater", "Lophophanes cristatus", "Carduelis carduelis",
             "Accipiter gentilis", "Dendrocopos major", "Garrulus glandarius", "Loxia pytyopsittacus", 
             "Loxia scotica", "Spinus spinus", "Cyanistes caeruleus", "Regulus regulus", 
             "Aegithalos caudatus", "Saxicola rubicola", "Certhia familiaris", "Troglodytes troglodytes")
distances <- c("20", "40", "60", "80", "100")
transects <- c("GGFT_1", "GGFT_2", "DFT_1", "DFT_2", "DFT_3", "DHFT_1", "DHFT_2", "DHFT_3", 
           "CFT_1", "CFT_2", "CFT_3", "RFT_1", "RFT_2", "RFT_3", "TFT_2", "TFT_3") 

complete_grid <- expand.grid(
  transect_id = transects, 
  distance_m = distances, 
  scientific_name = species, 
  stringsAsFactors = FALSE
)


# Collapsing detections to one row per site/distance/species combination
detections_collapsed <- playback_truedet %>%
  group_by(transect_id, distance_m, Scientific.name) %>%
  summarise(detected = max(is_true_detection), .groups = 'drop')


# Joining and creating zero-filled dataset
zero_filled <- complete_grid %>%
  left_join(
    detections_collapsed,
    by = c("transect_id" = "transect_id", 
           "distance_m" = "distance_m", 
           "scientific_name" = "Scientific.name")
  ) %>%
  mutate(detected = replace_na(detected, 0)) %>%
  distinct(transect_id, distance_m, scientific_name, .keep_all = TRUE) %>%
  mutate(distance_m = as.numeric(distance_m))


#Creation of basal area and pine LAI correction, Basal area = π * (DBH/2)^2
#Converting Diameter at Breast Height measurements from mm to m                 
full_zero_filled <- zero_filled %>%
  # First join
  left_join(
    raw_cov %>% mutate(distance_m = as.numeric(distance_m)),
    by = c("transect_id", "distance_m")
  ) %>%
  # Second join
  left_join(
    raw_LAI,
    by = c("transect_id", "stand_type")
  ) %>%
  # All mutations
  mutate(
    # Convert DBH from mm to m
    dbh1_m = dbh1_mm / 1000,
    dbh2_m = dbh2_mm / 1000,
    dbh3_m = dbh3_mm / 1000,
    dbh4_m = dbh4_mm / 1000,
    dbh5_m = dbh5_mm / 1000,
    
    # Calculate basal area for each tree
    ba1 = ifelse(!is.na(dbh1_m), pi * (dbh1_m/2)^2, 0),
    ba2 = ifelse(!is.na(dbh2_m), pi * (dbh2_m/2)^2, 0),
    ba3 = ifelse(!is.na(dbh3_m), pi * (dbh3_m/2)^2, 0),
    ba4 = ifelse(!is.na(dbh4_m), pi * (dbh4_m/2)^2, 0),
    ba5 = ifelse(!is.na(dbh5_m), pi * (dbh5_m/2)^2, 0),
    
    # Total basal area per plot
    total_ba_plot = mean(c(ba1, ba2, ba3, ba4, ba5)) * stems_count_10x10,
    
    # Extract site from transect_id
    site = str_split_fixed(transect_id, "[_]", 2)[,1]
  )


