###PROBABILITY OF DETECTION SPECIES MODEL ANALYSIS (simple model)###
#Shows 15 species have a distance effect, stand_type insignificant for all
# Create empty data frame to store model results
model_results <- data.frame(
  species = character(),
  n_obs = integer(),
  n_detected = integer(),
  distance_estimate = numeric(),
  distance_se = numeric(),
  distance_z = numeric(),
  distance_p = numeric(),
  standtype_estimate = numeric(),
  standtype_se = numeric(),
  standtype_z = numeric(),
  standtype_p = numeric(),
  converged = logical(),
  model_status = character(),
  stringsAsFactors = FALSE
)


# Filter to only species with sufficient data
species_to_model <- species_diagnostics %>%
  filter(sufficient_data == TRUE) %>%
  pull(species)

cat("Modeling", length(species_to_model), "species with sufficient data\n\n")

# Loop through each species
for (sp in species_to_model) {
  
  cat("===================================\n")
  cat("Modeling:", sp, "\n")
  
  # Subset data for this species
  sp_data <- full_zero_filled %>%
    filter(scientific_name == sp)
  
  cat("  N observations:", nrow(sp_data), "\n")
  cat("  N detected:", sum(sp_data$detected), "\n")
  
  # Fit model
  tryCatch({
    
    # Fit the model
    sp_model <- glmmTMB(
      detected ~ distance_m + stand_type + (1|site),
      data = sp_data,
      family = binomial()
    )
    
    # Check convergence
    converged <- sp_model$sdr$pdHess
    
    # Get summary
    sp_summary <- summary(sp_model)
    
    # Convert coefficients to data frame
    coef_df <- as.data.frame(sp_summary$coefficients$cond)
    
    # Extract distance_m coefficients
    if ("distance_m" %in% rownames(coef_df)) {
      dist_est <- coef_df["distance_m", "Estimate"]
      dist_se <- coef_df["distance_m", "Std. Error"]
      dist_z <- coef_df["distance_m", "z value"]
      dist_p <- coef_df["distance_m", "Pr(>|z|)"]
    } else {
      dist_est <- dist_se <- dist_z <- dist_p <- NA
    }
    
    # Extract stand_typepine coefficients
    if ("stand_typepine" %in% rownames(coef_df)) {
      stand_est <- coef_df["stand_typepine", "Estimate"]
      stand_se <- coef_df["stand_typepine", "Std. Error"]
      stand_z <- coef_df["stand_typepine", "z value"]
      stand_p <- coef_df["stand_typepine", "Pr(>|z|)"]
    } else {
      stand_est <- stand_se <- stand_z <- stand_p <- NA
    }
    
    # Store results
    model_results <- rbind(model_results, data.frame(
      species = sp,
      n_obs = nrow(sp_data),
      n_detected = sum(sp_data$detected),
      distance_estimate = dist_est,
      distance_se = dist_se,
      distance_z = dist_z,
      distance_p = dist_p,
      standtype_estimate = stand_est,
      standtype_se = stand_se,
      standtype_z = stand_z,
      standtype_p = stand_p,
      converged = converged,
      model_status = ifelse(converged, "Success", "Convergence issue"),
      stringsAsFactors = FALSE
    ))
    
    cat("  Status: SUCCESS\n")
    cat("  Converged:", converged, "\n")
    cat("  Distance p-value:", round(dist_p, 4), "\n")
    cat("  Stand type p-value:", round(stand_p, 4), "\n")
    
  }, error = function(e) {
    
    # If model fails, store NA results
    model_results <<- rbind(model_results, data.frame(
      species = sp,
      n_obs = nrow(sp_data),
      n_detected = sum(sp_data$detected),
      distance_estimate = NA,
      distance_se = NA,
      distance_z = NA,
      distance_p = NA,
      standtype_estimate = NA,
      standtype_se = NA,
      standtype_z = NA,
      standtype_p = NA,
      converged = FALSE,
      model_status = paste("Error:", e$message),
      stringsAsFactors = FALSE
    ))
    
    cat("  Status: ERROR -", e$message, "\n")
  })
  
  cat("\n")
}





