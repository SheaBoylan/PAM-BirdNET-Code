###PROBABILITY OF DETECTION SPECIES MODEL (SIMPLE SCALED)###
##Shows 15 species have a distance effect, stand_type insignificant for all
species_models_simple <- list()
species_results_simple <- data.frame()

for (sp in unique(full_zero_filled$scientific_name)) {
  
  cat("Processing:", sp, "\n")
  
  sp_data <- full_zero_filled %>% 
    filter(scientific_name == sp)
  
  detection_rate <- mean(sp_data$detected, na.rm = TRUE)
  n_detections <- sum(sp_data$detected, na.rm = TRUE)
  
  if (n_detections > 5 & n_detections < nrow(sp_data) & nrow(sp_data) > 20) {
    
    tryCatch({
      sp_data_scaled <- sp_data %>%
        mutate(
          distance_sc = as.numeric(scale(distance_m))
        )
      
      sp_model_simple <- glmmTMB(
        detected ~ distance_sc + stand_type + (1 | site),
        data = sp_data_scaled,
        family = binomial()
      )
      
      # Check convergence
      converged <- sp_model_simple$sdr$pdHess
      
      species_models_simple[[sp]] <- sp_model_simple
      
      # Get summary
      sp_summary <- summary(sp_model_simple)
      coef_df <- as.data.frame(sp_summary$coefficients$cond)
      
      # Helper function to extract coefficients
      extract_coef <- function(var_name) {
        if (var_name %in% rownames(coef_df)) {
          est <- coef_df[var_name, "Estimate"]
          se <- coef_df[var_name, "Std. Error"]
          z <- coef_df[var_name, "z value"]
          p <- coef_df[var_name, "Pr(>|z|)"]
          ci_low <- est - 1.96 * se
          ci_high <- est + 1.96 * se
          return(list(est = est, se = se, z = z, p = p, ci_low = ci_low, ci_high = ci_high))
        } else {
          return(list(est = NA, se = NA, z = NA, p = NA, ci_low = NA, ci_high = NA))
        }
      }
      
      # Extract coefficients
      dist <- extract_coef("distance_sc")
      stand <- extract_coef("stand_typepine")
      
      # Store results
      species_results_simple <- rbind(species_results_simple, data.frame(
        species = sp,
        n_obs = nrow(sp_data),
        n_detected = n_detections,
        
        distance_est = dist$est,
        distance_se = dist$se,
        distance_ci_low = dist$ci_low,
        distance_ci_high = dist$ci_high,
        distance_z = dist$z,
        distance_p = dist$p,
        
        stand_est = stand$est,
        stand_se = stand$se,
        stand_ci_low = stand$ci_low,
        stand_ci_high = stand$ci_high,
        stand_z = stand$z,
        stand_p = stand$p,
        
        converged = converged,
        stringsAsFactors = FALSE
      ))
      
      cat("  Status: SUCCESS\n")
      cat("  Converged:", converged, "\n")
      cat("  Distance p-value:", round(dist$p, 4), "\n\n")
      
    }, error = function(e) {
      cat("  Status: ERROR -", e$message, "\n\n")
    })
  }
}

# View results
