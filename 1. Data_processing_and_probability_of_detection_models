###SPECIES DIAGNOSTICS LOOP###


# Get unique species
species_list <- unique(full_zero_filled$scientific_name)

cat("Total number of species:", length(species_list), "\n\n")


# Create empty data frame to store diagnostics
species_diagnostics <- data.frame(
  species = character(),
  n_obs = integer(),
  n_detected = integer(),
  n_not_detected = integer(),
  pct_detected = numeric(),
  n_sites = integer(),
  n_deciduous = integer(),
  n_pine = integer(),
  sufficient_data = logical(),
  stringsAsFactors = FALSE
)



# Loop through each species to check data
for (sp in species_list) {
  
  cat("Checking:", sp, "\n")
  
  # Subset data for this species
  sp_data <- full_zero_filled %>%
    filter(scientific_name == sp)
  
  # Calculate diagnostics
  n_obs <- nrow(sp_data)
  n_detected <- sum(sp_data$detected == 1)
  n_not_detected <- sum(sp_data$detected == 0)
  pct_detected <- (n_detected / n_obs) * 100
  n_sites <- length(unique(sp_data$site))
  n_deciduous <- sum(sp_data$stand_type == "deciduous")
  n_pine <- sum(sp_data$stand_type == "pine")
  
  # Check if sufficient data for modeling
  # Criteria: at least 2 detections AND 2 non-detections
  sufficient <- (n_detected >= 2 & n_not_detected >= 2)
  
  # Store diagnostics
  species_diagnostics <- rbind(species_diagnostics, data.frame(
    species = sp,
    n_obs = n_obs,
    n_detected = n_detected,
    n_not_detected = n_not_detected,
    pct_detected = round(pct_detected, 1),
    n_sites = n_sites,
    n_deciduous = n_deciduous,
    n_pine = n_pine,
    sufficient_data = sufficient,
    stringsAsFactors = FALSE
  ))
  
  cat("  Obs:", n_obs, "| Detected:", n_detected, "| Not detected:", n_not_detected, 
      "| Sites:", n_sites, "| Sufficient:", sufficient, "\n\n")
}


