)
summary(accuracy_veg_int5)
confint(accuracy_veg_int5)

# Betabinomial Accuracy Model 1 
accuracy_int_bb <- glmmTMB(
  accuracy_pct/100 ~ distance_m * stand_type +
    (1|expected_species) + (1|transect_id),
  data = accuracy_summary, family = betabinomial(), weights = n_total
)
summary(accuracy_int_bb)
confint(accuracy_int_bb)

# Betabinomial Accuracy Model 2
accuracy_int_bb_rs <- glmmTMB(
  accuracy_pct/100 ~ distance_m * stand_type +
    (1 + distance_m | expected_species) + (1|transect_id),
  data = accuracy_summary, family = betabinomial(), weights = n_total
)
summary(accuracy_int_bb_rs)
confint(accuracy_int_bb_rs)


# Model comparison
AIC(accuracy_int, 
