# NOTE ON TERMINOLOGY
# The variable 'accuracy' used throughout this code corresponds to 
# 'classification precision' as used in the main dissertation text.
# The variable 'masking' refers to 
# 'commmunity vocal activity' as used int the main dissertation text. 


###ACCURACY MODELS + BUILDING OF MASKING METRIC###

#Building playback dataframe
playback_detections <- raw_detections %>%
  filter(
    verification_category %in% c("playback_true", "playback_false"),
    !is.na(distance_m)  # Drop this rogue row
  ) %>%
  mutate(
    transect_id = gsub(" ", "_", trimws(transect_id)),
    distance_m = as.numeric(distance_m),
    correct = if_else(Scientific.name == expected_species, 1, 0)
  )


#Defining accuracy metric
accuracy_summary <- playback_detections %>%
  group_by(transect_id, expected_species, distance_m) %>%
  summarise(
    n_total = n(),
    n_correct = sum(verification_category == "playback_true"),
    n_incorrect = sum(verification_category == "playback_false"),
    accuracy_pct = (n_correct / n_total) * 100,
    .groups = 'drop'
  )

print(accuracy_summary)


#Joining on covariates and recomputing total_ba_plot to avoid row duplication
accuracy_summary <- accuracy_summary %>%
  left_join(
    raw_cov %>% 
      select(transect_id, distance_m, stand_type,
             stems_count_10x10,
             dbh1_mm, dbh2_mm, dbh3_mm, dbh4_mm, dbh5_mm),
    by = c("transect_id", "distance_m")
  ) %>%
  left_join(
    raw_LAI,
    by = c("transect_id", "stand_type")
  ) %>%
  mutate(
    ba1 = ifelse(!is.na(dbh1_mm), pi * ((dbh1_mm/1000)/2)^2, 0),
    ba2 = ifelse(!is.na(dbh2_mm), pi * ((dbh2_mm/1000)/2)^2, 0),
    ba3 = ifelse(!is.na(dbh3_mm), pi * ((dbh3_mm/1000)/2)^2, 0),
    ba4 = ifelse(!is.na(dbh4_mm), pi * ((dbh4_mm/1000)/2)^2, 0),
    ba5 = ifelse(!is.na(dbh5_mm), pi * ((dbh5_mm/1000)/2)^2, 0),
    total_ba_plot = mean(c(ba1, ba2, ba3, ba4, ba5)) * stems_count_10x10
  )
# Checking for NAs
nrow(accuracy_summary)
sum(is.na(accuracy_summary$total_ba_plot))


#CALCULATING MASKING DATA FOR NON-TARGET DETECTIONS
masking_data <- raw_detections %>%
  filter(verification_category == "nontarget_true") %>%
  mutate(
    transect_id = gsub(" ", "_", trimws(transect_id)),
    distance_m = as.numeric(distance_m)
  ) %>%
  group_by(transect_id, distance_m) %>%
  summarise(
    n_nontarget = n(),
    .groups = 'drop'
  )

# Add to accuracy_summary
accuracy_summary <- accuracy_summary %>%
  left_join(masking_data, by = c("transect_id", "distance_m")) %>%
  mutate(n_nontarget = replace_na(n_nontarget, 0))

# Add to full_zero_filled
full_zero_filled <- full_zero_filled %>%
  left_join(masking_data, by = c("transect_id", "distance_m")) %>%
  mutate(n_nontarget = replace_na(n_nontarget, 0))

names(masking_data)
head(masking_data)

# Check
summary(accuracy_summary$n_nontarget)
summary(full_zero_filled$n_nontarget)

anti_join(accuracy_summary, masking_data, by = c("transect_id", "distance_m"))
masking_data %>% arrange(desc(n_nontarget))


# Are there genuinely no zero-masking instances in accuracy_summary?
accuracy_summary %>%
  filter(n_nontarget == 0)

# Compare distributions
hist(accuracy_summary$n_nontarget)
hist(full_zero_filled$n_nontarget)





###ACCURACY MODEL DISTANCE X STAND TYPE###
# Model 1: Simple interactive model between distance and stand_type
accuracy_int <- glmmTMB(
  accuracy_pct/100 ~ distance_m * stand_type + (1|expected_species) + (1|transect_id),
  data = accuracy_summary,
  family = binomial(),
  weights = n_total
)
summary(accuracy_int)
confint(accuracy_int)

# Model 2: Full stand covariate interactive model
accuracy_veg <- glmmTMB(
  accuracy_pct/100 ~ distance_m * stand_type + total_ba_plot + 
    canopy_LAI_conversion + ground_LAI_conversion + 
    (1|expected_species) + (1|transect_id),
  data = accuracy_summary,
  family = binomial(),
  weights = n_total
)
summary(accuracy_veg)
confint(accuracy_veg)

# Model 3: Full stand covariate model with 2 interactions 
accuracy_veg_int2 <- glmmTMB(
  accuracy_pct/100 ~ distance_m * stand_type + distance_m * total_ba_plot + 
    canopy_LAI_conversion + ground_LAI_conversion + 
    (1|expected_species) + (1|transect_id),
  data = accuracy_summary,
  family = binomial(),
  weights = n_total
)
summary(accuracy_veg_int2)
confint(accuracy_veg_int2)

# Model 4: Full stand covariate model with 3 interactions (ground LAI)
accuracy_veg_int3 <- glmmTMB(
  accuracy_pct/100 ~ distance_m * stand_type + distance_m * total_ba_plot + 
    canopy_LAI_conversion + distance_m * ground_LAI_conversion + 
    (1|expected_species) + (1|transect_id),
  data = accuracy_summary,
  family = binomial(),
  weights = n_total
)
summary(accuracy_veg_int3)
confint(accuracy_veg_int3)

# Model 5: Full stand covariate model 3 interactions (canopy LAI)
accuracy_veg_int4 <- glmmTMB(
  accuracy_pct/100 ~ distance_m * stand_type + distance_m * total_ba_plot + 
    distance_m * canopy_LAI_conversion + ground_LAI_conversion + 
    (1|expected_species) + (1|transect_id),
  data = accuracy_summary,
  family = binomial(),
  weights = n_total
)
summary(accuracy_veg_int4)
confint(accuracy_veg_int4)

# Model 6: Full stand LAI interact with each other
accuracy_veg_int5 <- glmmTMB(
  accuracy_pct/100 ~ distance_m * stand_type + distance_m * total_ba_plot + 
    canopy_LAI_conversion * ground_LAI_conversion + 
