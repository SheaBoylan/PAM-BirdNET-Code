# =============================================================================
# HELPER: Extract threshold distances from prediction dataframe
# =============================================================================

label_threshold <- function(distances, t) {
  if (length(distances) == 0) "Not achieved" else
    if (max(distances) >= 100) ">100m" else
      paste0(round(max(distances), 1), "m")
}

threshold_cols <- function(pred_df, group_var = NULL) {
  if (!is.null(group_var)) {
    pred_df <- pred_df %>% group_by(across(all_of(group_var)))
  }
  pred_df %>%
    summarise(
      across(everything(), ~ NA, .names = "drop"),
      .groups = "drop"
    ) %>%
    select(any_of(group_var)) %>%
    bind_cols(
      map_dfc(thresholds, function(t) {
        pred_df %>%
          { if (!is.null(group_var)) group_by(., across(all_of(group_var))) else . } %>%
          summarise(
            val = label_threshold(distance_m[fit >= t], t),
            .groups = "drop"
          ) %>%
          select(val) %>%
          setNames(paste0("p_", round(t * 100), "pct"))
      })
    )
}

rename_threshold_cols <- function(df) {
  names(df) <- gsub("p_95pct", "95%",
                    gsub("p_90pct", "90%",
                         gsub("p_80pct", "80%",
                              gsub("p_50pct", "50%",
                                   gsub("p_20pct", "20%",
                                        gsub("p_10pct", "10%",
                                             gsub("p_5pct",  "5%", names(df))))))))
  df
}


