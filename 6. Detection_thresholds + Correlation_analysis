# =============================================================================
# POPULATION-LEVEL THRESHOLD TABLE (detection + classification, by stand type)
# =============================================================================

build_pop_threshold <- function(pred_df, metric_name) {
  results <- data.frame()
  for (st in c("deciduous", "pine")) {
    st_pred <- pred_df %>% filter(stand_type == st)
    row <- data.frame(Metric = metric_name, `Stand Type` = st,
                      check.names = FALSE)
    for (t in thresholds) {
      col_name <- paste0(round(t * 100), "%")
      row[[col_name]] <- label_threshold(
        st_pred$distance_m[st_pred$fit >= t], t)
    }
    results <- bind_rows(results, row)
  }
  results
}

