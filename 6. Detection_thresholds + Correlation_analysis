# =============================================================================
# HELPER: Species-level threshold loop
# =============================================================================

get_species_thresholds <- function(species_list, newdata_fn, 
                                   model, by_stand = TRUE) {
  
  results <- data.frame()
  stands  <- c("deciduous", "pine")
  
  for (sp in species_list) {
    
    if (by_stand) {
      for (st in stands) {
        sp_pred <- newdata_fn(sp, st)
        sp_pred$fit <- predict(model, newdata = sp_pred,
                               type = "response", re.form = NULL,
                               allow.new.levels = TRUE)
        row <- data.frame(species = sp, stand_type = st)
        for (t in thresholds) {
          row[[paste0("p_", round(t*100), "pct")]] <-
            label_threshold(sp_pred$distance_m[sp_pred$fit >= t], t)
        }
        results <- bind_rows(results, row)
      }
    } else {
      pred_dec  <- predict(model, newdata = newdata_fn(sp, "deciduous"),
                           type = "response", re.form = NULL,
                           allow.new.levels = TRUE)
      pred_pine <- predict(model, newdata = newdata_fn(sp, "pine"),
                           type = "response", re.form = NULL,
                           allow.new.levels = TRUE)
      sp_pred        <- newdata_fn(sp, "deciduous")
      sp_pred$fit    <- (pred_dec + pred_pine) / 2
      row <- data.frame(species = sp)
      for (t in thresholds) {
        row[[paste0("p_", round(t*100), "pct")]] <-
          label_threshold(sp_pred$distance_m[sp_pred$fit >= t], t)
      }
      results <- bind_rows(results, row)
    }
  }
  
  results %>%
    arrange(species, if("stand_type" %in% names(.)) stand_type) %>%
    rename_threshold_cols() %>%
    rename(Species = species,
           any_of(c("Stand Type" = "stand_type")))
}


