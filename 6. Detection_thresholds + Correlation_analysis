# =============================================================================
# DETECTION vs CLASSIFICATION CORRELATION
# =============================================================================

detection_classification_comparison <- species_detection_rates %>%
  select(scientific_name, detection_rate) %>%
  left_join(species_accuracy %>% select(expected_species, accuracy_pct),
            by = c("scientific_name" = "expected_species")) %>%
  filter(!is.na(accuracy_pct))

# Spearman correlation
cor_test <- cor.test(detection_classification_comparison$detection_rate,
                     detection_classification_comparison$accuracy_pct,
                     method = "spearman")
print(cor_test)

# Save correlation table
cor_table <- data.frame(
  Test       = "Spearman's rank correlation",
  Variable_1 = "Detection rate (%)",
  Variable_2 = "Classification precision (%)",
  N          = nrow(detection_classification_comparison),
  rho        = round(cor_test$estimate, 3),
  S          = round(cor_test$statistic, 2),
  p_value    = round(cor_test$p.value, 3)
)

write.csv(cor_table,
          file.path(out_dir, "Detection_Classification_Correlation.csv"),
          row.names = FALSE)
cat("✓ Correlation table saved\n")

